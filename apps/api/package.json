{
  "name": "@price-intel/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./jobs": {
      "types": "./dist/jobs.d.ts",
      "default": "./dist/jobs.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "db:check": "tsx src/scripts/check-database.ts",
    "ebay:check": "tsx src/scripts/check-ebay.ts",
    "smoke:production": "tsx src/scripts/smoke-production.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@prisma/client": "^6.12.0",
    "cors": "^2.8.5",
    "csv-parse": "^7.0.1",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "fflate": "^0.8.3",
    "jose": "^6.2.3",
    "nodemailer": "^9.0.3",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.14",
    "@types/nodemailer": "^8.0.1",
    "prisma": "^6.12.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
