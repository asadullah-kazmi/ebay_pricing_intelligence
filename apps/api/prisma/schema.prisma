generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  OWNER
  ADMIN
  MANAGER
  CATALOG_OPERATOR
  PRICING_OPERATOR
  PUBLISHER
  VIEWER
}

enum ImportBatchStatus {
  UPLOADED
  PARSING
  VALIDATING
  REVIEW_REQUIRED
  READY_TO_COMMIT
  COMMITTING
  COMPLETED
  FAILED
}

enum ImportRowStatus {
  PENDING
  VALID
  WARNING
  INVALID
  COMMITTED
}

enum PartCondition {
  NEW
  USED
}

enum CatalogPartStatus {
  IMPORTED
  NEEDS_IMAGES
  IMPORT_ERROR
  READY_FOR_ENRICHMENT
  ARCHIVED
}

enum PartNumberType {
  PRIMARY
  OEM
  MPN
  INTERCHANGE
}

enum MediaStatus {
  UPLOADED
  PROCESSING
  READY
  QUARANTINED
  FAILED
}

enum WeightUnit {
  LB
  KG
}

enum DimensionUnit {
  IN
  CM
}

enum ImageMatchStrategy {
  MANIFEST
  SKU_FOLDER
  IMAGE_GROUP_FOLDER
  SKU_FILENAME
  MANUAL
  UNMATCHED
  AMBIGUOUS
}

enum ImageMatchStatus {
  MATCHED
  REVIEW_REQUIRED
  UNMATCHED
}

enum PricingJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  PARTIAL
  FAILED
}

enum PricingJobItemStatus {
  QUEUED
  RUNNING
  COMPLETED
  NO_MATCHES
  FAILED
}

enum PricingConditionMode {
  MATCH_PART
  ANY
  NEW
  USED
}

enum FitmentJobStatus {
  QUEUED
  RUNNING
  REVIEW_REQUIRED
  COMPLETED
  PARTIAL
  FAILED
}

enum FitmentJobItemStatus {
  QUEUED
  RUNNING
  REVIEW_REQUIRED
  NO_CANDIDATE
  APPROVED
  FAILED
}

enum EbayConnectionStatus {
  ACTIVE
  ERROR
  EXPIRED
  DISCONNECTED
}

enum IdempotencyStatus {
  IN_PROGRESS
  COMPLETED
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

enum DeadLetterStatus {
  OPEN
  REQUEUED
  RESOLVED
}

enum DeadLetterType {
  PRICING_ITEM
  FITMENT_ITEM
}

enum ListingDraftStatus {
  DRAFT
  BLOCKED
  READY
}

enum EbaySellerResourceType {
  PAYMENT_POLICY
  RETURN_POLICY
  FULFILLMENT_POLICY
  INVENTORY_LOCATION
}

enum EbayImageStatus {
  PENDING
  READY
  FAILED
}

enum InventoryPreparationJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum EbayInventorySyncJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum EbayOfferStatus {
  PREPARING
  FEES_READY
  PUBLISH_QUEUED
  PUBLISHED
  FAILED
}

enum EbayOfferJobAction {
  PREPARE
  PUBLISH
}

enum EbayOfferJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model Organization {
  id                   String                      @id @default(cuid())
  name                 String
  slug                 String                      @unique
  memberships          OrganizationMembership[]
  refreshSessions      RefreshSession[]
  importBatches        ImportBatch[]
  importRows           ImportRow[]
  vehicles             Vehicle[]
  parts                Part[]
  partNumbers          PartNumber[]
  inventoryItems       InventoryItem[]
  warehouses           Warehouse[]
  binLocations         BinLocation[]
  mediaAssets          MediaAsset[]
  partMedia            PartMedia[]
  importMediaMatches   ImportMediaMatch[]
  pricingJobs          PricingJob[]
  pricingJobItems      PricingJobItem[]
  competitorListings   CompetitorListingSnapshot[]
  fitmentJobs          FitmentJob[]
  fitmentJobItems      FitmentJobItem[]
  fitmentCandidates    FitmentCandidate[]
  fitmentApplications  FitmentApplication[]
  ebaySellerConnection EbaySellerConnection?
  ebayOAuthStates      EbayOAuthState[]
  idempotencyRecords   IdempotencyRecord[]
  outboxEvents         OutboxEvent[]
  deadLetterEntries    DeadLetterEntry[]
  listingDrafts        ListingDraft[]
  listingDraftVersions ListingDraftVersion[]
  ebaySellerResources  EbaySellerResource[]
  ebayPublishedImages  EbayPublishedImage[]
  inventoryPreparations EbayInventoryPreparation[]
  inventoryPreparationJobs InventoryPreparationJob[]
  ebayInventorySyncJobs EbayInventorySyncJob[]
  ebayOffers            EbayOffer[]
  ebayOfferJobs         EbayOfferJob[]
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
}

model User {
  id                  String                   @id @default(cuid())
  email               String                   @unique
  name                String?
  memberships         OrganizationMembership[]
  refreshSessions     RefreshSession[]
  createdImports      ImportBatch[]            @relation("ImportCreator")
  createdParts        Part[]                   @relation("PartCreator")
  createdPricingJobs  PricingJob[]             @relation("PricingJobCreator")
  createdFitmentJobs  FitmentJob[]             @relation("FitmentJobCreator")
  createdListingDrafts ListingDraft[]           @relation("ListingDraftCreator")
  updatedListingDrafts ListingDraft[]           @relation("ListingDraftUpdater")
  listingDraftVersions ListingDraftVersion[]    @relation("ListingDraftVersionCreator")
  connectedEbayStores EbaySellerConnection[]   @relation("EbayConnectionCreator")
  ebayOAuthStates     EbayOAuthState[]
  inventoryPreparations EbayInventoryPreparation[] @relation("InventoryPreparationCreator")
  createdInventoryPreparationJobs InventoryPreparationJob[] @relation("InventoryPreparationJobCreator")
  createdEbayInventorySyncJobs EbayInventorySyncJob[] @relation("EbayInventorySyncJobCreator")
  createdEbayOfferJobs  EbayOfferJob[] @relation("EbayOfferJobCreator")
  approvedEbayOffers    EbayOffer[]    @relation("EbayOfferApprover")
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
}

model OrganizationMembership {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, role])
}

model RefreshSession {
  id             String       @id
  userId         String
  organizationId String
  tokenHash      String       @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([userId, organizationId])
  @@index([expiresAt])
}

model EbaySellerConnection {
  id                      String               @id @default(cuid())
  organizationId          String               @unique
  connectedById           String
  environment             String
  status                  EbayConnectionStatus @default(ACTIVE)
  ebayUserId              String?
  username                String?
  accountType             String?
  registrationMarketplace String?
  scopes                  String[]
  accessTokenCiphertext   Bytes?
  accessTokenIv           Bytes?
  accessTokenTag          Bytes?
  refreshTokenCiphertext  Bytes?
  refreshTokenIv          Bytes?
  refreshTokenTag         Bytes?
  accessTokenExpiresAt    DateTime?
  refreshTokenExpiresAt   DateTime?
  lastRefreshedAt         DateTime?
  lastError               String?
  disconnectedAt          DateTime?
  organization            Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connectedBy             User                 @relation("EbayConnectionCreator", fields: [connectedById], references: [id], onDelete: Restrict)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@index([status])
  @@index([ebayUserId])
}

model EbayOAuthState {
  id             String       @id @default(cuid())
  stateHash      String       @unique
  organizationId String
  userId         String
  expiresAt      DateTime
  consumedAt     DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId, expiresAt])
  @@index([expiresAt])
}

model EbaySellerResource {
  id             String                 @id @default(cuid())
  organizationId String
  marketplace    String
  type           EbaySellerResourceType
  remoteId       String
  name           String?
  enabled        Boolean                @default(true)
  payload        Json
  fetchedAt      DateTime               @default(now())
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([organizationId, marketplace, type, remoteId])
  @@index([organizationId, marketplace, type])
}

model EbayCategoryMetadata {
  id          String   @id @default(cuid())
  marketplace String
  categoryId  String
  aspects     Json
  conditions  Json?
  fetchedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([marketplace, categoryId])
  @@index([fetchedAt])
}

model LegacyPricingPart {
  id        String    @id @default(cuid())
  oem       String    @unique
  brand     String?
  searches  Search[]
  listings  Listing[]
  createdAt DateTime  @default(now())
}

model ImportBatch {
  id                   String             @id @default(cuid())
  organizationId       String
  createdById          String
  originalFilename     String
  templateVersion      String
  checksum             String
  sourceFileKey        String?
  imageArchiveKey      String?
  imageArchiveChecksum String?
  status               ImportBatchStatus  @default(UPLOADED)
  totalRows            Int                @default(0)
  validRows            Int                @default(0)
  warningRows          Int                @default(0)
  invalidRows          Int                @default(0)
  imageMatchCount      Int                @default(0)
  imageReviewCount     Int                @default(0)
  imageUnmatchedCount  Int                @default(0)
  errors               Json?
  warnings             Json?
  imageIssues          Json?
  confirmedAt          DateTime?
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy            User               @relation("ImportCreator", fields: [createdById], references: [id], onDelete: Restrict)
  rows                 ImportRow[]
  mediaMatches         ImportMediaMatch[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([organizationId, checksum])
  @@index([organizationId, status, createdAt])
  @@index([createdById])
}

model ImportRow {
  id              String             @id @default(cuid())
  organizationId  String
  importBatchId   String
  rowNumber       Int
  rawData         Json
  normalizedData  Json?
  status          ImportRowStatus    @default(PENDING)
  errors          Json?
  warnings        Json?
  committedPartId String?            @unique
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  importBatch     ImportBatch        @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  committedPart   Part?              @relation("CommittedImportPart", fields: [committedPartId], references: [id], onDelete: SetNull)
  mediaMatches    ImportMediaMatch[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([importBatchId, rowNumber])
  @@index([organizationId, status])
}

model Vehicle {
  id             String       @id @default(cuid())
  organizationId String
  vin            String
  year           Int?
  make           String?
  model          String?
  trim           String?
  engine         String?
  bodyStyle      String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parts          Part[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, vin])
  @@index([organizationId, year, make, model])
}

model Part {
  id                   String               @id @default(cuid())
  organizationId       String
  sku                  String
  normalizedSku        String
  primaryPartNumber    String
  normalizedPartNumber String
  brand                String?
  partName             String?
  description          String?
  condition            PartCondition
  imageGroup           String?
  status               CatalogPartStatus    @default(IMPORTED)
  donorVehicleId       String?
  donorMileage         Int?
  donorColor           String?
  placement            String?
  notes                String?
  createdById          String
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  donorVehicle         Vehicle?             @relation(fields: [donorVehicleId], references: [id], onDelete: SetNull)
  createdBy            User                 @relation("PartCreator", fields: [createdById], references: [id], onDelete: Restrict)
  sourceImportRow      ImportRow?           @relation("CommittedImportPart")
  partNumbers          PartNumber[]
  inventoryItem        InventoryItem?
  media                PartMedia[]
  pricingJobItems      PricingJobItem[]
  fitmentJobItems      FitmentJobItem[]
  fitmentApplications  FitmentApplication[]
  listingDrafts        ListingDraft[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@unique([organizationId, normalizedSku])
  @@index([organizationId, normalizedPartNumber])
  @@index([organizationId, status, createdAt])
  @@index([donorVehicleId])
  @@index([createdById])
}

model PartNumber {
  id              String         @id @default(cuid())
  organizationId  String
  partId          String
  type            PartNumberType
  value           String
  normalizedValue String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  part            Part           @relation(fields: [partId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())

  @@unique([partId, type, normalizedValue])
  @@index([organizationId, normalizedValue])
}

model Warehouse {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  code           String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  binLocations   BinLocation[]
  inventoryItems InventoryItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([organizationId, code])
}

model BinLocation {
  id             String          @id @default(cuid())
  organizationId String
  warehouseId    String
  code           String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  inventoryItems InventoryItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([warehouseId, code])
  @@index([organizationId])
}

model InventoryItem {
  id             String         @id @default(cuid())
  organizationId String
  partId         String         @unique
  warehouseId    String?
  binLocationId  String?
  quantity       Int            @default(0)
  cost           Decimal        @db.Decimal(12, 2)
  currency       String         @default("USD")
  weight         Decimal?       @db.Decimal(10, 3)
  weightUnit     WeightUnit?
  length         Decimal?       @db.Decimal(10, 2)
  width          Decimal?       @db.Decimal(10, 2)
  height         Decimal?       @db.Decimal(10, 2)
  dimensionUnit  DimensionUnit?
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  part           Part           @relation(fields: [partId], references: [id], onDelete: Cascade)
  warehouse      Warehouse?     @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  binLocation    BinLocation?   @relation(fields: [binLocationId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId, quantity])
  @@index([warehouseId, binLocationId])
}

model MediaAsset {
  id               String             @id @default(cuid())
  organizationId   String
  storageKey       String
  originalFilename String
  mimeType         String
  byteSize         Int
  checksum         String
  width            Int?
  height           Int?
  status           MediaStatus        @default(UPLOADED)
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parts            PartMedia[]
  importMatches    ImportMediaMatch[]
  ebayImages       EbayPublishedImage[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([organizationId, storageKey])
  @@index([organizationId, checksum])
  @@index([organizationId, status])
}

model EbayPublishedImage {
  id                   String          @id @default(cuid())
  organizationId       String
  mediaAssetId         String
  environment          String
  status               EbayImageStatus @default(PENDING)
  sourceChecksum       String
  ebayImageId          String?
  imageUrl             String?
  maxDimensionImageUrl String?
  expirationDate       DateTime?
  lastError            String?
  uploadedAt           DateTime?
  organization         Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mediaAsset           MediaAsset      @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@unique([organizationId, mediaAssetId, environment])
  @@index([organizationId, status])
  @@index([expirationDate])
}

model PartMedia {
  id             String       @id @default(cuid())
  organizationId String
  partId         String
  mediaAssetId   String
  displayOrder   Int
  approved       Boolean      @default(false)
  altText        String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  part           Part         @relation(fields: [partId], references: [id], onDelete: Cascade)
  mediaAsset     MediaAsset   @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([partId, mediaAssetId])
  @@unique([partId, displayOrder])
  @@index([organizationId, mediaAssetId])
}

model ImportMediaMatch {
  id             String             @id @default(cuid())
  organizationId String
  importBatchId  String
  importRowId    String?
  mediaAssetId   String
  sourcePath     String
  strategy       ImageMatchStrategy
  status         ImageMatchStatus
  displayOrder   Int
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  importBatch    ImportBatch        @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  importRow      ImportRow?         @relation(fields: [importRowId], references: [id], onDelete: SetNull)
  mediaAsset     MediaAsset         @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([importBatchId, sourcePath])
  @@index([organizationId, status])
  @@index([importRowId, displayOrder])
  @@index([mediaAssetId])
}

model PricingJob {
  id             String               @id @default(cuid())
  organizationId String
  createdById    String
  marketplace    String
  conditionMode  PricingConditionMode @default(MATCH_PART)
  status         PricingJobStatus     @default(QUEUED)
  totalItems     Int
  completedItems Int                  @default(0)
  noMatchItems   Int                  @default(0)
  failedItems    Int                  @default(0)
  attemptCount   Int                  @default(0)
  leaseOwner     String?
  leaseExpiresAt DateTime?
  lastError      String?
  startedAt      DateTime?
  completedAt    DateTime?
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User                 @relation("PricingJobCreator", fields: [createdById], references: [id], onDelete: Restrict)
  items          PricingJobItem[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([organizationId, createdAt])
  @@index([organizationId, status])
  @@index([status, leaseExpiresAt])
  @@index([createdById])
}

model PricingJobItem {
  id               String                      @id @default(cuid())
  organizationId   String
  pricingJobId     String
  partId           String
  queryPartNumber  String
  condition        String
  status           PricingJobItemStatus        @default(QUEUED)
  competitorCount  Int                         @default(0)
  lowest           Decimal?                    @db.Decimal(12, 2)
  average          Decimal?                    @db.Decimal(12, 2)
  median           Decimal?                    @db.Decimal(12, 2)
  highest          Decimal?                    @db.Decimal(12, 2)
  recommendedPrice Decimal?                    @db.Decimal(12, 2)
  currency         String?
  error            String?
  attemptCount     Int                         @default(0)
  startedAt        DateTime?
  completedAt      DateTime?
  organization     Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pricingJob       PricingJob                  @relation(fields: [pricingJobId], references: [id], onDelete: Cascade)
  part             Part                        @relation(fields: [partId], references: [id], onDelete: Cascade)
  listings         CompetitorListingSnapshot[]
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  @@unique([pricingJobId, partId])
  @@index([organizationId, status])
  @@index([partId, completedAt])
}

model CompetitorListingSnapshot {
  id               String         @id @default(cuid())
  organizationId   String
  pricingJobItemId String
  listingId        String
  title            String
  seller           String
  price            Decimal        @db.Decimal(12, 2)
  shipping         Decimal        @db.Decimal(12, 2)
  landedPrice      Decimal        @db.Decimal(12, 2)
  currency         String
  condition        String
  marketplace      String
  url              String
  matchedOn        String[]
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pricingJobItem   PricingJobItem @relation(fields: [pricingJobItemId], references: [id], onDelete: Cascade)
  capturedAt       DateTime       @default(now())

  @@unique([pricingJobItemId, listingId])
  @@index([organizationId, listingId])
  @@index([pricingJobItemId, landedPrice])
}

model FitmentJob {
  id               String           @id @default(cuid())
  organizationId   String
  createdById      String
  marketplace      String
  status           FitmentJobStatus @default(QUEUED)
  totalItems       Int
  reviewedItems    Int              @default(0)
  noCandidateItems Int              @default(0)
  failedItems      Int              @default(0)
  attemptCount     Int              @default(0)
  leaseOwner       String?
  leaseExpiresAt   DateTime?
  lastError        String?
  startedAt        DateTime?
  completedAt      DateTime?
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy        User             @relation("FitmentJobCreator", fields: [createdById], references: [id], onDelete: Restrict)
  items            FitmentJobItem[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([organizationId, createdAt])
  @@index([organizationId, status])
  @@index([status, leaseExpiresAt])
}

model FitmentJobItem {
  id                  String               @id @default(cuid())
  organizationId      String
  fitmentJobId        String
  partId              String
  query               String
  status              FitmentJobItemStatus @default(QUEUED)
  categoryId          String?
  categoryName        String?
  approvedCandidateId String?              @unique
  metadataVersion     String?
  applicationCount    Int                  @default(0)
  error               String?
  attemptCount        Int                  @default(0)
  startedAt           DateTime?
  completedAt         DateTime?
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fitmentJob          FitmentJob           @relation(fields: [fitmentJobId], references: [id], onDelete: Cascade)
  part                Part                 @relation(fields: [partId], references: [id], onDelete: Cascade)
  candidates          FitmentCandidate[]   @relation("FitmentItemCandidates")
  approvedCandidate   FitmentCandidate?    @relation("ApprovedFitmentCandidate", fields: [approvedCandidateId], references: [id], onDelete: SetNull)
  applications        FitmentApplication[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([fitmentJobId, partId])
  @@index([organizationId, status])
  @@index([partId, completedAt])
}

model WorkerHeartbeat {
  id          String   @id
  service     String
  status      String
  startedAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  stoppedAt   DateTime?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([service, lastSeenAt])
  @@index([status, lastSeenAt])
}

model IdempotencyRecord {
  id             String            @id @default(cuid())
  organizationId String
  operation      String
  key            String
  requestHash    String
  status         IdempotencyStatus @default(IN_PROGRESS)
  responseStatus Int?
  responseBody   Json?
  expiresAt      DateTime
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([organizationId, operation, key])
  @@index([expiresAt])
}

model OutboxEvent {
  id             String       @id @default(cuid())
  organizationId String
  topic          String
  aggregateType  String
  aggregateId    String
  payload        Json
  status         OutboxStatus @default(PENDING)
  attemptCount   Int          @default(0)
  nextAttemptAt  DateTime     @default(now())
  leaseOwner     String?
  leaseExpiresAt DateTime?
  lastError      String?
  publishedAt    DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status, nextAttemptAt])
  @@index([aggregateType, aggregateId])
  @@index([organizationId, createdAt])
}

model DeadLetterEntry {
  id             String           @id @default(cuid())
  organizationId String
  type           DeadLetterType
  jobId          String
  itemId         String
  payload        Json
  error          String
  attempts       Int
  status         DeadLetterStatus @default(OPEN)
  requeuedAt     DateTime?
  resolvedAt     DateTime?
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([type, itemId])
  @@index([organizationId, status, createdAt])
  @@index([jobId])
}

model ListingDraft {
  id                  String             @id @default(cuid())
  organizationId      String
  partId              String
  marketplace         String
  status              ListingDraftStatus @default(DRAFT)
  title               String
  description         String?
  categoryId          String?
  condition           PartCondition
  ebayCondition       String?
  price               Decimal?           @db.Decimal(12, 2)
  currency            String              @default("USD")
  quantity            Int                 @default(0)
  aspects             Json
  paymentPolicyId     String?
  returnPolicyId      String?
  shippingPolicyId    String?
  merchantLocationKey String?
  validationIssues    Json?
  validatedAt         DateTime?
  liveValidatedAt     DateTime?
  version             Int                @default(1)
  createdById         String
  updatedById         String
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  part                Part               @relation(fields: [partId], references: [id], onDelete: Cascade)
  createdBy           User               @relation("ListingDraftCreator", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy           User               @relation("ListingDraftUpdater", fields: [updatedById], references: [id], onDelete: Restrict)
  versions            ListingDraftVersion[]
  inventoryPreparations EbayInventoryPreparation[]
  inventoryPreparationJobs InventoryPreparationJob[]
  ebayInventorySyncJobs EbayInventorySyncJob[]
  ebayOffers            EbayOffer[]
  ebayOfferJobs         EbayOfferJob[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([partId, marketplace])
  @@index([organizationId, status, updatedAt])
  @@index([organizationId, marketplace])
}

model EbayInventoryPreparation {
  id                   String       @id @default(cuid())
  organizationId       String
  listingDraftId       String
  draftVersion         Int
  sku                  String
  payloadHash          String
  inventoryPayload     Json
  compatibilityPayload Json?
  warnings             Json
  createdById          String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listingDraft         ListingDraft @relation(fields: [listingDraftId], references: [id], onDelete: Cascade)
  createdBy            User         @relation("InventoryPreparationCreator", fields: [createdById], references: [id], onDelete: Restrict)
  job                  InventoryPreparationJob?
  syncJob              EbayInventorySyncJob?
  createdAt            DateTime     @default(now())

  @@unique([listingDraftId, draftVersion])
  @@index([organizationId, createdAt])
  @@index([payloadHash])
}

model EbayInventorySyncJob {
  id                     String                     @id @default(cuid())
  organizationId         String
  createdById            String
  listingDraftId         String
  preparationId          String                     @unique
  draftVersion           Int
  sku                    String
  payloadHash            String
  status                 EbayInventorySyncJobStatus @default(QUEUED)
  attemptCount           Int                        @default(0)
  leaseOwner             String?
  leaseExpiresAt         DateTime?
  lastError              String?
  inventoryWrittenAt     DateTime?
  compatibilityWrittenAt DateTime?
  startedAt              DateTime?
  completedAt            DateTime?
  organization           Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy              User                       @relation("EbayInventorySyncJobCreator", fields: [createdById], references: [id], onDelete: Restrict)
  listingDraft           ListingDraft               @relation(fields: [listingDraftId], references: [id], onDelete: Cascade)
  preparation            EbayInventoryPreparation   @relation(fields: [preparationId], references: [id], onDelete: Cascade)
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  offer                  EbayOffer?

  @@index([organizationId, createdAt])
  @@index([status, leaseExpiresAt])
}

model EbayOffer {
  id                 String          @id @default(cuid())
  organizationId     String
  listingDraftId     String          @unique
  inventorySyncJobId String          @unique
  preparationId      String
  draftVersion       Int
  sku                String
  marketplace        String
  payloadHash        String
  offerPayload       Json
  ebayOfferId        String?
  ebayListingId      String?
  status             EbayOfferStatus @default(PREPARING)
  feeResponse        Json?
  feeTotal           Decimal?        @db.Decimal(12, 2)
  feeCurrency        String?
  warnings           Json?
  lastError          String?
  approvedById       String?
  approvedAt         DateTime?
  publishedAt        DateTime?
  organization       Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listingDraft       ListingDraft    @relation(fields: [listingDraftId], references: [id], onDelete: Cascade)
  inventorySyncJob   EbayInventorySyncJob @relation(fields: [inventorySyncJobId], references: [id], onDelete: Restrict)
  approvedBy         User?           @relation("EbayOfferApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  jobs               EbayOfferJob[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([organizationId, status, updatedAt])
  @@index([ebayOfferId])
  @@index([ebayListingId])
}

model EbayOfferJob {
  id             String             @id @default(cuid())
  organizationId String
  createdById    String
  listingDraftId String
  ebayOfferId    String
  draftVersion   Int
  action         EbayOfferJobAction
  status         EbayOfferJobStatus @default(QUEUED)
  attemptCount   Int                @default(0)
  leaseOwner     String?
  leaseExpiresAt DateTime?
  lastError      String?
  startedAt      DateTime?
  completedAt    DateTime?
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User               @relation("EbayOfferJobCreator", fields: [createdById], references: [id], onDelete: Restrict)
  listingDraft   ListingDraft       @relation(fields: [listingDraftId], references: [id], onDelete: Cascade)
  ebayOffer      EbayOffer          @relation(fields: [ebayOfferId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([ebayOfferId, action, draftVersion])
  @@index([organizationId, createdAt])
  @@index([status, leaseExpiresAt])
}

model InventoryPreparationJob {
  id               String                        @id @default(cuid())
  organizationId   String
  createdById      String
  listingDraftId   String
  draftVersion     Int
  status           InventoryPreparationJobStatus @default(QUEUED)
  attemptCount     Int                           @default(0)
  leaseOwner       String?
  leaseExpiresAt   DateTime?
  lastError        String?
  preparationId    String?                       @unique
  startedAt        DateTime?
  completedAt      DateTime?
  organization     Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy        User                          @relation("InventoryPreparationJobCreator", fields: [createdById], references: [id], onDelete: Restrict)
  listingDraft     ListingDraft                  @relation(fields: [listingDraftId], references: [id], onDelete: Cascade)
  preparation      EbayInventoryPreparation?     @relation(fields: [preparationId], references: [id], onDelete: SetNull)
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt

  @@unique([listingDraftId, draftVersion])
  @@index([organizationId, createdAt])
  @@index([status, leaseExpiresAt])
}

model ListingDraftVersion {
  id             String       @id @default(cuid())
  organizationId String
  listingDraftId String
  version        Int
  snapshot       Json
  reason         String?
  createdById    String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listingDraft   ListingDraft @relation(fields: [listingDraftId], references: [id], onDelete: Cascade)
  createdBy      User         @relation("ListingDraftVersionCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now())

  @@unique([listingDraftId, version])
  @@index([organizationId, createdAt])
}

model FitmentCandidate {
  id               String          @id @default(cuid())
  organizationId   String
  fitmentJobItemId String
  epid             String
  title            String
  brand            String?
  imageUrl         String?
  productWebUrl    String?
  score            Int
  matchedOn        String[]
  aspects          Json?
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fitmentJobItem   FitmentJobItem  @relation("FitmentItemCandidates", fields: [fitmentJobItemId], references: [id], onDelete: Cascade)
  approvedFor      FitmentJobItem? @relation("ApprovedFitmentCandidate")
  createdAt        DateTime        @default(now())

  @@unique([fitmentJobItemId, epid])
  @@index([organizationId, epid])
  @@index([fitmentJobItemId, score])
}

model FitmentApplication {
  id               String         @id @default(cuid())
  organizationId   String
  fitmentJobItemId String
  partId           String
  fingerprint      String
  properties       Json
  notes            String?
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fitmentJobItem   FitmentJobItem @relation(fields: [fitmentJobItemId], references: [id], onDelete: Cascade)
  part             Part           @relation(fields: [partId], references: [id], onDelete: Cascade)
  approvedAt       DateTime       @default(now())

  @@unique([fitmentJobItemId, fingerprint])
  @@index([organizationId, partId])
}

model Search {
  id               String            @id @default(cuid())
  oem              String
  marketplace      String
  searchedAt       DateTime          @default(now())
  competitorCount  Int
  lowest           Decimal?          @db.Decimal(12, 2)
  average          Decimal?          @db.Decimal(12, 2)
  median           Decimal?          @db.Decimal(12, 2)
  highest          Decimal?          @db.Decimal(12, 2)
  recommendedPrice Decimal?          @db.Decimal(12, 2)
  currency         String?
  part             LegacyPricingPart @relation(fields: [oem], references: [oem])
  priceCaptures    PriceHistory[]

  @@index([oem, searchedAt])
}

model Listing {
  id          String            @id
  title       String
  seller      String
  price       Decimal           @db.Decimal(12, 2)
  shipping    Decimal           @db.Decimal(12, 2)
  currency    String
  condition   String
  marketplace String
  url         String
  matchedOn   String[]
  oem         String
  part        LegacyPricingPart @relation(fields: [oem], references: [oem])
  prices      PriceHistory[]
  firstSeenAt DateTime          @default(now())
  lastSeenAt  DateTime          @updatedAt
}

model PriceHistory {
  id         String   @id @default(cuid())
  listingId  String
  searchId   String
  price      Decimal  @db.Decimal(12, 2)
  shipping   Decimal  @db.Decimal(12, 2)
  capturedAt DateTime @default(now())
  listing    Listing  @relation(fields: [listingId], references: [id])
  search     Search   @relation(fields: [searchId], references: [id], onDelete: Cascade)

  @@index([listingId, capturedAt])
  @@index([searchId])
}
