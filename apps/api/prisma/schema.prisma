generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  OWNER
  ADMIN
  MANAGER
  CATALOG_OPERATOR
  PRICING_OPERATOR
  PUBLISHER
  VIEWER
}

enum ImportBatchStatus {
  UPLOADED
  PARSING
  VALIDATING
  REVIEW_REQUIRED
  READY_TO_COMMIT
  COMMITTING
  COMPLETED
  FAILED
}

enum ImportRowStatus {
  PENDING
  VALID
  WARNING
  INVALID
  COMMITTED
}

enum PartCondition {
  NEW
  USED
}

enum CatalogPartStatus {
  IMPORTED
  NEEDS_IMAGES
  IMPORT_ERROR
  READY_FOR_ENRICHMENT
  ARCHIVED
}

enum PartNumberType {
  PRIMARY
  OEM
  MPN
  INTERCHANGE
}

enum MediaStatus {
  UPLOADED
  PROCESSING
  READY
  QUARANTINED
  FAILED
}

enum WeightUnit {
  LB
  KG
}

enum DimensionUnit {
  IN
  CM
}

enum ImageMatchStrategy {
  MANIFEST
  SKU_FOLDER
  IMAGE_GROUP_FOLDER
  SKU_FILENAME
  MANUAL
  UNMATCHED
  AMBIGUOUS
}

enum ImageMatchStatus {
  MATCHED
  REVIEW_REQUIRED
  UNMATCHED
}

model Organization {
  id                 String                   @id @default(cuid())
  name               String
  slug               String                   @unique
  memberships        OrganizationMembership[]
  refreshSessions    RefreshSession[]
  importBatches      ImportBatch[]
  importRows         ImportRow[]
  vehicles           Vehicle[]
  parts              Part[]
  partNumbers        PartNumber[]
  inventoryItems     InventoryItem[]
  warehouses         Warehouse[]
  binLocations       BinLocation[]
  mediaAssets        MediaAsset[]
  partMedia          PartMedia[]
  importMediaMatches ImportMediaMatch[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
}

model User {
  id              String                   @id @default(cuid())
  email           String                   @unique
  name            String?
  memberships     OrganizationMembership[]
  refreshSessions RefreshSession[]
  createdImports  ImportBatch[]            @relation("ImportCreator")
  createdParts    Part[]                   @relation("PartCreator")
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
}

model OrganizationMembership {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, role])
}

model RefreshSession {
  id             String       @id
  userId         String
  organizationId String
  tokenHash      String       @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([userId, organizationId])
  @@index([expiresAt])
}

model LegacyPricingPart {
  id        String    @id @default(cuid())
  oem       String    @unique
  brand     String?
  searches  Search[]
  listings  Listing[]
  createdAt DateTime  @default(now())
}

model ImportBatch {
  id                   String             @id @default(cuid())
  organizationId       String
  createdById          String
  originalFilename     String
  templateVersion      String
  checksum             String
  sourceFileKey        String?
  imageArchiveKey      String?
  imageArchiveChecksum String?
  status               ImportBatchStatus  @default(UPLOADED)
  totalRows            Int                @default(0)
  validRows            Int                @default(0)
  warningRows          Int                @default(0)
  invalidRows          Int                @default(0)
  imageMatchCount      Int                @default(0)
  imageReviewCount     Int                @default(0)
  imageUnmatchedCount  Int                @default(0)
  errors               Json?
  warnings             Json?
  imageIssues          Json?
  confirmedAt          DateTime?
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy            User               @relation("ImportCreator", fields: [createdById], references: [id], onDelete: Restrict)
  rows                 ImportRow[]
  mediaMatches         ImportMediaMatch[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([organizationId, checksum])
  @@index([organizationId, status, createdAt])
  @@index([createdById])
}

model ImportRow {
  id              String             @id @default(cuid())
  organizationId  String
  importBatchId   String
  rowNumber       Int
  rawData         Json
  normalizedData  Json?
  status          ImportRowStatus    @default(PENDING)
  errors          Json?
  warnings        Json?
  committedPartId String?            @unique
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  importBatch     ImportBatch        @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  committedPart   Part?              @relation("CommittedImportPart", fields: [committedPartId], references: [id], onDelete: SetNull)
  mediaMatches    ImportMediaMatch[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([importBatchId, rowNumber])
  @@index([organizationId, status])
}

model Vehicle {
  id             String       @id @default(cuid())
  organizationId String
  vin            String
  year           Int?
  make           String?
  model          String?
  trim           String?
  engine         String?
  bodyStyle      String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parts          Part[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, vin])
  @@index([organizationId, year, make, model])
}

model Part {
  id                   String            @id @default(cuid())
  organizationId       String
  sku                  String
  normalizedSku        String
  primaryPartNumber    String
  normalizedPartNumber String
  brand                String?
  partName             String?
  description          String?
  condition            PartCondition
  imageGroup           String?
  status               CatalogPartStatus @default(IMPORTED)
  donorVehicleId       String?
  donorMileage         Int?
  donorColor           String?
  placement            String?
  notes                String?
  createdById          String
  organization         Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  donorVehicle         Vehicle?          @relation(fields: [donorVehicleId], references: [id], onDelete: SetNull)
  createdBy            User              @relation("PartCreator", fields: [createdById], references: [id], onDelete: Restrict)
  sourceImportRow      ImportRow?        @relation("CommittedImportPart")
  partNumbers          PartNumber[]
  inventoryItem        InventoryItem?
  media                PartMedia[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@unique([organizationId, normalizedSku])
  @@index([organizationId, normalizedPartNumber])
  @@index([organizationId, status, createdAt])
  @@index([donorVehicleId])
  @@index([createdById])
}

model PartNumber {
  id              String         @id @default(cuid())
  organizationId  String
  partId          String
  type            PartNumberType
  value           String
  normalizedValue String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  part            Part           @relation(fields: [partId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())

  @@unique([partId, type, normalizedValue])
  @@index([organizationId, normalizedValue])
}

model Warehouse {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  code           String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  binLocations   BinLocation[]
  inventoryItems InventoryItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([organizationId, code])
}

model BinLocation {
  id             String          @id @default(cuid())
  organizationId String
  warehouseId    String
  code           String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  inventoryItems InventoryItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([warehouseId, code])
  @@index([organizationId])
}

model InventoryItem {
  id             String         @id @default(cuid())
  organizationId String
  partId         String         @unique
  warehouseId    String?
  binLocationId  String?
  quantity       Int            @default(0)
  cost           Decimal        @db.Decimal(12, 2)
  currency       String         @default("USD")
  weight         Decimal?       @db.Decimal(10, 3)
  weightUnit     WeightUnit?
  length         Decimal?       @db.Decimal(10, 2)
  width          Decimal?       @db.Decimal(10, 2)
  height         Decimal?       @db.Decimal(10, 2)
  dimensionUnit  DimensionUnit?
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  part           Part           @relation(fields: [partId], references: [id], onDelete: Cascade)
  warehouse      Warehouse?     @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  binLocation    BinLocation?   @relation(fields: [binLocationId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId, quantity])
  @@index([warehouseId, binLocationId])
}

model MediaAsset {
  id               String             @id @default(cuid())
  organizationId   String
  storageKey       String
  originalFilename String
  mimeType         String
  byteSize         Int
  checksum         String
  width            Int?
  height           Int?
  status           MediaStatus        @default(UPLOADED)
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parts            PartMedia[]
  importMatches    ImportMediaMatch[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([organizationId, storageKey])
  @@index([organizationId, checksum])
  @@index([organizationId, status])
}

model PartMedia {
  id             String       @id @default(cuid())
  organizationId String
  partId         String
  mediaAssetId   String
  displayOrder   Int
  approved       Boolean      @default(false)
  altText        String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  part           Part         @relation(fields: [partId], references: [id], onDelete: Cascade)
  mediaAsset     MediaAsset   @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([partId, mediaAssetId])
  @@unique([partId, displayOrder])
  @@index([organizationId, mediaAssetId])
}

model ImportMediaMatch {
  id             String             @id @default(cuid())
  organizationId String
  importBatchId  String
  importRowId    String?
  mediaAssetId   String
  sourcePath     String
  strategy       ImageMatchStrategy
  status         ImageMatchStatus
  displayOrder   Int
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  importBatch    ImportBatch        @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  importRow      ImportRow?         @relation(fields: [importRowId], references: [id], onDelete: SetNull)
  mediaAsset     MediaAsset         @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([importBatchId, sourcePath])
  @@index([organizationId, status])
  @@index([importRowId, displayOrder])
  @@index([mediaAssetId])
}

model Search {
  id               String            @id @default(cuid())
  oem              String
  marketplace      String
  searchedAt       DateTime          @default(now())
  competitorCount  Int
  lowest           Decimal?          @db.Decimal(12, 2)
  average          Decimal?          @db.Decimal(12, 2)
  median           Decimal?          @db.Decimal(12, 2)
  highest          Decimal?          @db.Decimal(12, 2)
  recommendedPrice Decimal?          @db.Decimal(12, 2)
  currency         String?
  part             LegacyPricingPart @relation(fields: [oem], references: [oem])
  priceCaptures    PriceHistory[]

  @@index([oem, searchedAt])
}

model Listing {
  id          String            @id
  title       String
  seller      String
  price       Decimal           @db.Decimal(12, 2)
  shipping    Decimal           @db.Decimal(12, 2)
  currency    String
  condition   String
  marketplace String
  url         String
  matchedOn   String[]
  oem         String
  part        LegacyPricingPart @relation(fields: [oem], references: [oem])
  prices      PriceHistory[]
  firstSeenAt DateTime          @default(now())
  lastSeenAt  DateTime          @updatedAt
}

model PriceHistory {
  id         String   @id @default(cuid())
  listingId  String
  searchId   String
  price      Decimal  @db.Decimal(12, 2)
  shipping   Decimal  @db.Decimal(12, 2)
  capturedAt DateTime @default(now())
  listing    Listing  @relation(fields: [listingId], references: [id])
  search     Search   @relation(fields: [searchId], references: [id], onDelete: Cascade)

  @@index([listingId, capturedAt])
  @@index([searchId])
}
